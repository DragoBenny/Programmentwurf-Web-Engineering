doctype html 
html(lang="en")
    head 
        meta(charset="UTF-8")
        link(rel='stylesheet' href='/css/login-register.css')
        title Registers
    body 
        form
            label(id="label-register") Registrieren
            input(id="email-field" class="form-element" type="text" placeholder="E-Mail")
            input(id="username-field" class="form-element" type="text" placeholder="Username")
            input(id="password-field" class="form-element" type="text" placeholder="Passwort")
            input(id="confirmed-password-field" class="form-element" type="text" placeholder="Passwort bestätigen")
            input(id="register-button" class="form-element" type="submit" value="Registrieren")
            <a href="/profile/login">oder hier anmelden</a>
            label(id="message-field" class="form-element" ) #{message}
        script(type="text/javascript" src="/scripts/register.js")